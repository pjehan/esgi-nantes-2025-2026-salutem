{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - {{ doctor.fullName }}
{% endblock %}

{% block body %}
    <nav class="breadcrumb">
        <div class="container">
            <a href="{{ path('app_home') }}">Accueil</a> / <a href="index.html#doctors">Nos docteurs</a> / <span>{{ doctor.fullName }}</span>
        </div>
    </nav>

    <section class="doctor-profile">
        <div class="container">
            <aside class="doctor-card">
                <img src="{{ asset('uploads/' ~ doctor.photo) }}" alt="{{ doctor.fullName }}">
                <ul class="doctor-meta">
                    <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path fill="currentColor" d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
                        <a href="tel:{{ doctor.phone }}">{{ doctor.phone }}</a>
                    </li>
                    <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path fill="currentColor" d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48L48 64zM0 176L0 384c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-208L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
                        <a href="mailto:{{ doctor.email }}">{{ doctor.email }}</a>
                    </li>
                </ul>
                <a href="#appointment" class="btn btn-light">Prendre rendez-vous</a>
            </aside>

            <article class="doctor-content">
                <h1>{{ doctor.fullName }}</h1>
                <p class="specialty">
                    {% for specialty in doctor.specialties %}
                        {{ specialty.name }}
                        {% if not loop.last %}/{% endif %}
                    {% endfor %}
                </p>
                <p>{{ doctor.description }}</p>

                <h3>Parcours</h3>
                <ul>
                    <li>Doctorat en médecine, Université de Nantes (2004)</li>
                    <li>Diplôme universitaire d'ostéopathie (2007)</li>
                    <li>Praticien à la maison de santé Salutem depuis 2012</li>
                </ul>

                <h3>Domaines d'intervention</h3>
                <div class="tags">
                    <span>Douleurs lombaires</span>
                    <span>Suivi du sportif</span>
                    <span>Pédiatrie</span>
                    <span>Homéopathie</span>
                </div>

                <a href="index.html#doctors" class="btn btn-dark">Retour à la liste des docteurs</a>
            </article>
        </div>
    </section>
{% endblock %}

