{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - Ajouter un docteur
{% endblock %}

{% block body %}
    <div class="container">

        <h1>Ajouter un docteur</h1>

        {{ form_start(form) }}
            {{ form_row(form.firstName) }}
            {{ form_row(form.lastName) }}
            {{ form_row(form.photo) }}
            {{ form_row(form.phone) }}
            {{ form_row(form.email) }}
            {{ form_row(form.description) }}
            {{ form_row(form.specialties) }}

            <button type="submit" class="btn btn-dark">Enregistrer</button>

        {{ form_end(form) }}
    </div>
{% endblock %}

